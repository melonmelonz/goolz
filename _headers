# ── Security headers (apply to everything) ────────────────────
# X-Frame-Options + frame-ancestors are SAMEORIGIN/'self' so the
# Win95 desktop at /next-chapter can iframe /games/pwg/ without
# losing protection against external sites embedding goolz.org.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' static.cloudflareinsights.com; connect-src 'self' wss://goolz.org wss://*.pages.dev https:; frame-src 'self' https:; media-src 'self' data: blob:; worker-src 'self' blob:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
  X-Robots-Tag: index, follow

# ── Long-cache static assets ──────────────────────────────────
/styles.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# ── HTML: short cache so updates propagate fast ───────────────
/*.html
  Cache-Control: public, max-age=300, stale-while-revalidate=3600
